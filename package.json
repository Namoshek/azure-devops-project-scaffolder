{
  "name": "ado-project-scaffolder",
  "version": "1.0.0",
  "description": "Azure DevOps extension for project scaffolding from templates",
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "start": "webpack serve --mode development",
    "package": "npm run build && tfx extension create --manifest-globs vss-extension.json",
    "package:dev": "tfx extension create --manifest-globs vss-extension.json --overrides-file vss-extension.dev.json",
    "clean": "rimraf dist",
    "check": "npm run typecheck && npm run lint && npm run test",
    "test": "jest --silent",
    "test:watch": "jest --watch --silent",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "create-dev-cert": "dotnet dev-certs https --trust && dotnet dev-certs https --export-path dev.crt -np --format pem"
  },
  "dependencies": {
    "azure-devops-extension-api": "^4.270.0",
    "azure-devops-extension-sdk": "^4.2.0",
    "azure-devops-ui": "^2.275.0",
    "mustache": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "azure-devops-ui": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "eslint-plugin-react": {
      "eslint": "$eslint"
    },
    "eslint-plugin-react-hooks": {
      "eslint": "$eslint"
    }
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/mustache": "^4.2.6",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.6.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "rimraf": "^6.1.3",
    "style-loader": "^4.0.0",
    "tfx-cli": "^0.23.3",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.62.1",
    "webpack": "^5.108.3",
    "webpack-cli": "^7.1.0",
    "webpack-dev-server": "^5.2.5"
  }
}
