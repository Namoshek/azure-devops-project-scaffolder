{
  "name": "ado-project-scaffolder",
  "version": "0.1.0",
  "description": "Azure DevOps extension for project scaffolding from templates",
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "npm run build && tfx extension create --manifest-globs vss-extension.json",
    "clean": "rimraf dist",
    "check": "npm run typecheck && npm run lint && npm run test",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix"
  },
  "dependencies": {
    "azure-devops-extension-api": "^4.270.0",
    "azure-devops-extension-sdk": "^4.2.0",
    "azure-devops-ui": "^2.271.0",
    "mustache": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "overrides": {
    "azure-devops-ui": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "eslint-plugin-react": {
      "eslint": "$eslint"
    },
    "eslint-plugin-react-hooks": {
      "eslint": "$eslint"
    }
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/mustache": "^4.2.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "rimraf": "^6.1.3",
    "style-loader": "^4.0.0",
    "tfx-cli": "^0.23.1",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2"
  }
}
