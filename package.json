{
  "name": "ado-project-scaffolder",
  "version": "0.1.0",
  "description": "Azure DevOps extension for project scaffolding from templates",
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "npm run build && tfx extension create --manifest-globs vss-extension.json",
    "clean": "rimraf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix"
  },
  "dependencies": {
    "azure-devops-extension-api": "^4.0.0",
    "azure-devops-extension-sdk": "^4.0.0",
    "azure-devops-ui": "^2.270.0",
    "js-yaml": "^4.1.0",
    "mustache": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mustache": "^4.2.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.8.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^30.3.0",
    "rimraf": "^5.0.5",
    "style-loader": "^3.3.3",
    "tfx-cli": "^0.23.1",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.2",
    "typescript-eslint": "^8.57.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
