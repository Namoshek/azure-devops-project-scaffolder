{
  "manifestVersion": 1,
  "id": "ado-project-scaffolder",
  "publisher": "namoshek",
  "version": "0.13.3",
  "name": "Project Scaffolder",
  "description": "Scaffold repositories and pipelines across your Azure DevOps projects from your own templates — guided, parameterized, and non-destructive.",
  "public": false,
  "categories": ["Azure Repos", "Azure Pipelines"],
  "tags": [
    "scaffolding",
    "templates",
    "projects",
    "repos",
    "pipelines",
    "automation",
    "generator",
    "boilerplate",
    "yaml",
    "devops"
  ],
  "icons": {
    "default": "images/logo.png"
  },
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "demands": ["api-version/6.0"],
  "branding": {
    "color": "rgb(32, 31, 30)",
    "theme": "dark"
  },
  "content": {
    "details": {
      "path": "docs/overview.md"
    }
  },
  "links": {
    "getstarted": {
      "uri": "https://github.com/Namoshek/azure-devops-project-scaffolder"
    },
    "learn": {
      "uri": "https://github.com/Namoshek/azure-devops-project-scaffolder/blob/main/docs/template_authoring.md"
    },
    "support": {
      "uri": "https://github.com/Namoshek/azure-devops-project-scaffolder/issues"
    },
    "issues": {
      "uri": "https://github.com/Namoshek/azure-devops-project-scaffolder/issues"
    }
  },
  "repository": {
    "type": "git",
    "uri": "https://github.com/Namoshek/azure-devops-project-scaffolder"
  },
  "CustomerQnASupport": {
    "enablemarketplaceqna": "false",
    "url": "https://github.com/Namoshek/azure-devops-project-scaffolder/issues"
  },
  "screenshots": [
    { "path": "images/screenshot_template_selection.png" },
    { "path": "images/screenshot_template_parameterization.png" },
    { "path": "images/screenshot_template_summary_permission_error.png" },
    { "path": "images/screenshot_template_scaffolding_progress.png" },
    { "path": "images/screenshot_admin_hub.png" }
  ],
  "contributions": [
    {
      "id": "project-scaffolding-hub",
      "type": "ms.vss-web.hub",
      "description": "Project Scaffolding page under Project Settings",
      "targets": ["ms.vss-web.project-admin-hub-group"],
      "properties": {
        "name": "Project Scaffolding",
        "order": 100,
        "uri": "dist/Hub/index.html"
      }
    },
    {
      "id": "collection-settings-hub",
      "type": "ms.vss-web.hub",
      "description": "Project Scaffolding settings page under Organization Settings (collection admins only)",
      "targets": ["ms.vss-web.collection-admin-hub-group"],
      "properties": {
        "name": "Project Scaffolding",
        "order": 100,
        "uri": "dist/AdminHub/index.html"
      }
    }
  ],
  "scopes": ["vso.agentpools", "vso.build_execute", "vso.code_manage", "vso.project"],
  "files": [
    {
      "path": "dist",
      "addressable": true
    },
    {
      "path": "images",
      "addressable": true
    },
    {
      "path": "docs",
      "addressable": true
    }
  ]
}
