{
  "name": "ado-project-scaffolder",
  "version": "0.1.0",
  "description": "Azure DevOps extension for project scaffolding from templates",
  "scripts": {
    "build": "webpack --mode production && npm run copy-html",
    "build:dev": "webpack --mode development && npm run copy-html",
    "copy-html": "node -e \"const{cpSync,mkdirSync}=require('fs');mkdirSync('dist/Hub',{recursive:true});cpSync('src/Hub/index.html','dist/Hub/index.html');\"",
    "watch": "webpack --mode development --watch",
    "package": "npm run build && tfx extension create --manifest-globs vss-extension.json",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "azure-devops-extension-api": "^4.0.0",
    "azure-devops-extension-sdk": "^4.0.0",
    "azure-devops-ui": "^2.270.0",
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "css-loader": "^6.8.1",
    "rimraf": "^5.0.5",
    "style-loader": "^3.3.3",
    "tfx-cli": "^0.23.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
